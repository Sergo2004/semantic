   "cell_type": "code",
   "source": [
    "# Получаем предсказания\n",
    "y_pred = (model.predict(X_test, verbose=0) > 0.5).astype(int).flatten()\n",
    "#Что происходит: модель делает предсказания на тестовой выборке и преобразует их в бинарные метки (0 или 1).\n",
    "\n",
    "#Разбор по частям:\n",
    "\n",
    "#1.model.predict(X_test, verbose=0):\n",
    "\n",
    "#Модель выдаёт предсказания для всех примеров из тестовой выборки X_test.\n",
    "\n",
    "#Поскольку выходной слой использует активацию sigmoid, результат — вероятности принадлежности к классу 1 в диапазоне [0,1].\n",
    "\n",
    "#verbose=0 отключает вывод прогресса в консоль.\n",
    "\n",
    "##Результат: массив вероятностей, например: [0.87, 0.12, 0.95, 0.43, ...].\n",
    "\n",
    "#2.(... > 0.5):\n",
    "\n",
    "#Каждое значение сравнивается с порогом 0.5.\n",
    "\n",
    "#Если вероятность > 0.5 → True (предсказание — класс 1, положительный отзыв).\n",
    "\n",
    "#Если вероятность ≤ 0.5 → False (предсказание — класс 0, отрицательный отзыв).\n",
    "\n",
    "#Результат: булевый массив, например: [True, False, True, False, ...].\n",
    "\n",
    "#3..astype(int):\n",
    "\n",
    "#Булевые значения преобразуются в целые числа: True → 1, False → 0.\n",
    "\n",
    "#Результат: целочисленный массив, например: [1, 0, 1, 0, ...].\n",
    "\n",
    "#4..flatten():\n",
    "\n",
    "#Преобразует многомерный массив (если он есть) в одномерный вектор.\n",
    "\n",
    "#Обеспечивает совместимость формы y_pred с формой y_test для дальнейшего вычисления метрик.\n",
    "\n",
    "#Финальный результат: одномерный массив бинарных предсказаний, например: [1, 0, 1, 0].\n",
    "# Считаем метрики\n",
    "f1  = f1_score(y_test, y_pred)\n",
    "pre = precision_score(y_test, y_pred)\n",
    "rec = recall_score(y_test, y_pred)\n",
    "#Что происходит: вычисляются ключевые метрики для оценки качества бинарной классификации. Используются истинные метки y_test и предсказанные метки y_pred.\n",
    "\n",
    "#Разбор метрик:\n",
    "\n",
    "#1.Precision (точность):\n",
    "#Смысл: доля действительно положительных среди всех примеров, которые модель отнесла к положительному классу.\n",
    "#2.Recall (полнота):\n",
    "#Смысл: доля верно найденных положительных примеров среди всех реально положительных примеров.\n",
    "#3.F1‑score (F‑мера):\n",
    "#Гармоническое среднее Precision и Recall.\n",
    "#Учитывает баланс между точностью и полнотой.\n",
    "print(f\"F1-score:  {f1:.4f}\")\n",
    "print(f\"Precision: {pre:.4f}\")\n",
    "print(f\"Recall:    {rec:.4f}\")"
